LAE_API_URL=http://127.0.0.1:8080
LAE_API_HOST=0.0.0.0
LAE_API_PORT=8080
LAE_ENVIRONMENT=development
# Billing is capability-scoped and disabled by default. In dev/staging only,
# set LAE_BILLING_DRIVER=mock and inject every value below from local secret
# tooling. Production must stay disabled until a real provider adapter exists.
LAE_BILLING_DRIVER=disabled
# LAE_MOCK_PRICING_JSON must be versioned JSON with currency plus pro/ultra
# monthly/yearly integer minor-unit prices. No commercial price is bundled.
# LAE_BILLING_HMAC_KEY is intentionally omitted (base64, at least 256 bit).
# LAE_MOCK_PAYMENT_SIGNING_KEY is intentionally omitted (a different base64 key).
# LAE_MOCK_PAYMENT_MERCHANT_ID is intentionally omitted.
# LAE_MOCK_CHECKOUT_BASE_URL is intentionally omitted (HTTPS or localhost).
LAE_MOCK_CHECKOUT_TTL_SECONDS=600
LAE_AGENT_CONTROLLER_HOST=0.0.0.0
LAE_AGENT_CONTROLLER_PORT=8081
# LAE_DEPLOY_TOKEN is intentionally omitted. Supply it through a secret store
# or stdin and never commit it to an env file.

# API/worker durable source-analysis binding. Supply the HMAC key from the
# platform secret store; the public API receives no Luma service token.
LAE_LUMA_CLUSTER_ID=luma-primary
LAE_LUMA_SERVICE_PRINCIPAL_ID=lae-worker
LAE_WORKER_STATE_HMAC_KEY_VERSION=1
# LAE_WORKER_STATE_HMAC_KEY is intentionally omitted (base64, at least 256 bit).
LAE_SOURCE_LEASE_TTL_SECONDS=900

# Identity and application-catalog runtime. Generate every key independently;
# omitted values intentionally make readiness fail closed.
# LAE_DATABASE_URL is intentionally omitted (postgresql+asyncpg secret DSN).
# LAE_AUTH_HMAC_KEY is intentionally omitted (base64, at least 256 bit).
LAE_AUTH_HMAC_KEY_VERSION=1
LAE_EMAIL_DRIVER=console
LAE_PUBLIC_LOGIN_URL=http://127.0.0.1:3000/login
# LAE_APPLICATION_IDEMPOTENCY_HMAC_KEY is intentionally omitted.
# LAE_DEPLOYMENT_IDEMPOTENCY_HMAC_KEY is intentionally omitted.
LAE_ENVIRONMENT_AEAD_KEY_VERSION=1
# LAE_ENVIRONMENT_AEAD_KEYS is intentionally omitted. It is a JSON object
# mapping versions to base64-encoded, exactly 32-byte AES keys.
# LAE_ENVIRONMENT_CHECKSUM_HMAC_KEY is intentionally omitted.

# Private Git connection capability. AEAD keys must decode to exactly 32 bytes;
# HMAC keys and the idempotency key must contain at least 32 bytes.
LAE_SOURCE_CONNECTION_KEY_VERSION=1
# LAE_SOURCE_CONNECTION_AEAD_KEYS is intentionally omitted (versioned JSON).
# LAE_SOURCE_CONNECTION_HMAC_KEYS is intentionally omitted (versioned JSON).
# LAE_SOURCE_CONNECTION_IDEMPOTENCY_HMAC_KEY is intentionally omitted.

# Static upload storage is a separate capability. Keep disabled until a real
# S3-compatible bucket and task-bound Builder redemption broker are configured.
LAE_UPLOAD_DRIVER=disabled
LAE_UPLOAD_ANALYSIS_BROKER_ENABLED=0
# LAE_UPLOAD_HMAC_KEY is intentionally omitted (base64, at least 256 bit).
