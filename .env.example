# Copy this file to .env and fill only the values you need.
# .env is ignored by Git.

# Cloudflare DNS API token with Zone Read + DNS Edit for your domain zone.
# Used by manager bootstrap and deploy to create/update control and service DNS records.
CLOUDFLARE_API_TOKEN=

# Public IP or DNS name that Cloudflare A/CNAME records should point to.
# Usually this is the manager/edge server public IP.
LUMA_DNS_EDGE_TARGET=

# Optional proxy subscription URL for egress setup.
# Required only when you want image-pull proxying or service runtime proxying with proxy: true.
EGRESS_SUBSCRIPTION_URL=

# Optional sudo password fallback for servers without passwordless sudo.
LUMA_SUDO_PASSWORD=

# Optional Tailscale auth key for private worker joins, home nodes, or tailscale-relay services.
TAILSCALE_AUTHKEY=

# Required on the manager for Traefik/Let's Encrypt HTTPS certificate registration.
TRAEFIK_ACME_EMAIL=

# Optional LAE integration for the manager-hosted luma-control Nomad job.
# Every *_FILE path must be a private regular file below /opt/luma/control.
LUMA_LAE_SERVICE_PRINCIPALS_FILE=
LUMA_LAE_RUNTIME_SERVICE_PRINCIPALS_FILE=
LUMA_LAE_PLAN_SIGNING_KEYS_FILE=

# Immutable analyzer allowlist and non-secret LAE Builder/Runtime policy.
LUMA_BUILDER_ANALYZE_IMAGE_DIGEST=
LUMA_LAE_BUILDER_ALLOW_ANONYMOUS_REGISTRY=
LUMA_LAE_BUILDER_REGISTRY_INSECURE=
LUMA_LAE_BUILDER_EXTERNAL_REGISTRIES_JSON=
# Internal positive-admission runner names; never project these to tenants.
LUMA_LAE_RUNTIME_NODE_ALLOWLIST_JSON=
LUMA_LAE_RUNTIME_STORAGE_CLASS=
LUMA_LAE_RUNTIME_VERIFY_TIMEOUT_SECONDS=

LUMA_CREDENTIAL_BROKER_URL=
LUMA_CREDENTIAL_BROKER_TIMEOUT_SECONDS=
LUMA_CREDENTIAL_BROKER_TOKEN_FILE=

LUMA_OBJECT_SOURCE_BROKER_URL=
LUMA_OBJECT_SOURCE_BROKER_TIMEOUT_SECONDS=
LUMA_OBJECT_SOURCE_BROKER_TOKEN_FILE=

LUMA_LAE_ADMIN_API_URL=
LUMA_LAE_ADMIN_TIMEOUT_SECONDS=
LUMA_LAE_ADMIN_TOKEN_FILE=
